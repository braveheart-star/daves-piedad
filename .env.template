# Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# ===========================================
# EmailJS Configuration (for Contact Form)
# ===========================================
# Get these values from your EmailJS dashboard at https://www.emailjs.com/
# See EMAILJS_SETUP.md for detailed setup instructions

# Your EmailJS Public Key (Account â†’ General â†’ Public Key)
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=ddd

# Your EmailJS Service ID (Email Services â†’ Your Service â†’ Service ID)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=ddd

# Your EmailJS Template ID (Email Templates â†’ Your Template â†’ Template ID)
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=ddd

# ===========================================
# Application Configuration
# ===========================================

# Application Environment (development, production, test)
NODE_ENV=development

# Next.js Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# Optional: Analytics & Monitoring
# ===========================================

# Google Analytics (if you want to add analytics)
# NEXT_PUBLIC_GA_ID=your_google_analytics_id

# Sentry (if you want to add error monitoring)
# SENTRY_DSN=your_sentry_dsn

# ===========================================
# Optional: Database (if you add backend features)
# ===========================================

# Database URL (if you add a database)
# DATABASE_URL=your_database_connection_string

# ===========================================
# Optional: Authentication (if you add auth features)
# ===========================================

# NextAuth.js Configuration (if you add authentication)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your_nextauth_secret

# OAuth Providers (if you add social login)
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret

# ===========================================
# Optional: External APIs (if you add integrations)
# ===========================================

# OpenAI API (if you add AI features)
# OPENAI_API_KEY=your_openai_api_key

# Stripe (if you add payment features)
# STRIPE_PUBLIC_KEY=your_stripe_public_key
# STRIPE_SECRET_KEY=your_stripe_secret_key

# ===========================================
# Setup Instructions
# ===========================================
# 1. Copy this file: cp .env.template .env.local
# 2. Fill in your actual values for the required variables
# 3. Never commit .env.local to version control
# 4. Restart your development server after making changes
